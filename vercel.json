{
    "version": 2,
    "name": "aisd-intel",
    "buildCommand": "python3 fix.py",
    "outputDirectory": ".",
    "routes": [
          { "src": "/(.*)", "dest": "/index.html" }
    ],
    "headers": [
          {
                  "source": "/(.*)",
                  "headers": [
                            { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" },
                            { "key": "X-Content-Type-Options", "value": "nosniff" }
                  ]
          }
    ]
}
